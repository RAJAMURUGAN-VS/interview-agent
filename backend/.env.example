PERPLEXITY_API_KEY=
MURF_API_KEY=
ASSEMBLYAI_API_KEY=
FIRECRAWL_API_KEY=
YOUTUBE_DATA_API_KEY=

# ── Pipedream Connect (YouTube OAuth for Playlist Generation) ─────────────
# To get these credentials:
# 1. Go to https://pipedream.com and sign in
# 2. Navigate to your project settings
# 3. Create an OAuth app or find your existing credentials
# 4. Copy CLIENT_ID and CLIENT_SECRET below
# 5. Your PROJECT_ID should be in project URL (proj_xxxxx)
PIPEDREAM_CLIENT_ID=
PIPEDREAM_CLIENT_SECRET=
PIPEDREAM_PROJECT_ID=
PIPEDREAM_ENVIRONMENT=development

# ── Tavily Search API (for AI Doubt Solver) ────────────────────────────────
# To get your API key:
# 1. Go to https://tavily.com and sign up
# 2. Navigate to your dashboard
# 3. Copy your API key
# Note: Each question costs 3 API credits (one per search type)

